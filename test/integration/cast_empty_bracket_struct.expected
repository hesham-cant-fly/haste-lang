; ModuleID = 'test/integration/cast_empty_bracket_struct.haste'
source_filename = "test/integration/cast_empty_bracket_struct.haste"

%struct.type.Job.0 = type { %struct.type.string.1 }
%struct.type.string.1 = type { ptr, i64 }
%struct.type.Person.2 = type { %struct.type.string.1, %struct.type.Job.0 }

@.str.0 = private unnamed_addr constant [9 x i8] c"Engineer\00"
@my_job = constant %struct.type.Job.0 { %struct.type.string.1 { ptr @.str.0, i64 8 } }
@.str.1 = private unnamed_addr constant [7 x i8] c"Hesham\00"
@.str.2 = private unnamed_addr constant [6 x i8] c"Coder\00"
@me = constant %struct.type.Person.2 { %struct.type.string.1 { ptr @.str.1, i64 6 }, %struct.type.Job.0 { %struct.type.string.1 { ptr @.str.2, i64 5 } } }
