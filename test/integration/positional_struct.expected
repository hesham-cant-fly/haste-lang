; ModuleID = 'test/integration/positional_struct.haste'
source_filename = "test/integration/positional_struct.haste"

%struct.type.Vec2.0 = type { float, float }
%struct.type.Vec3.1 = type { float, float, float }
%struct.type.Mixed.2 = type { i32, i32, i32 }
%struct.type.Nested.3 = type { %struct.type.Vec2.0, i32 }

@pos = constant %struct.type.Vec2.0 { float 1.000000e+00, float 2.000000e+00 }
@pos_partial = constant %struct.type.Vec2.0 { float 3.000000e+00, float 0.000000e+00 }
@pos2 = constant %struct.type.Vec3.1 { float 2.000000e+00, float 3.000000e+00, float 4.000000e+00 }
@pos3 = constant %struct.type.Vec3.1 { float 5.000000e+00, float 1.000000e+00, float 1.000000e+00 }
@m1 = constant %struct.type.Mixed.2 { i32 1, i32 2, i32 3 }
@m2 = constant %struct.type.Mixed.2 { i32 4, i32 10, i32 5 }
@m3 = constant %struct.type.Mixed.2 { i32 6, i32 7, i32 8 }
@n1 = constant %struct.type.Nested.3 { %struct.type.Vec2.0 { float 1.000000e+00, float 2.000000e+00 }, i32 42 }
