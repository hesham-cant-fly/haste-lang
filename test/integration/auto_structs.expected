; ModuleID = 'test/integration/auto_structs.haste'
source_filename = "test/integration/auto_structs.haste"

%struct.type.Outer.0 = type { %struct.type.string.1, %struct.type.Inner.2 }
%struct.type.string.1 = type { ptr, i64 }
%struct.type.Inner.2 = type { %struct.type.string.1 }
%struct.type.auto.3 = type { i32, i32 }
%struct.type.auto.4 = type {}
%struct.type.auto.5 = type { %struct.type.auto.6 }
