@.str.0 = private unnamed_addr constant [6 x i8] c"outer\00"
@.str.1 = private unnamed_addr constant [6 x i8] c"inner\00"
@me = constant %struct.type.Outer.0 { %struct.type.string.1 { ptr @.str.0, i64 5 }, %struct.type.Inner.2 { %struct.type.string.1 { ptr @.str.1, i64 5 } } }
